# GRP Support AI — environment template
# Copy to /etc/grp-api.env on the host, fill values, then:
#   sudo chown root:root /etc/grp-api.env && sudo chmod 600 /etc/grp-api.env
#   sudo systemctl restart grp-api

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ES_URL=https://localhost:9200
ES_USER=elastic
ES_PASSWORD=                    # rotate via: elasticsearch-reset-password -u elastic

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...    # console.anthropic.com → API keys

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=                     # gen: openssl rand -base64 48
RETENTION_API_KEY=              # gen: openssl rand -hex 32  (chat retention cron)

# ── Frontend ──────────────────────────────────────────────────────────────────
# Public origin where users hit the React app. Must match the cert hostname.
# Example for IP-only deploys via nip.io: https://173.212.247.3.nip.io
FRONTEND_URL=https://173.212.247.3.nip.io
# Public base for HMAC-signed image URLs. Same vhost, /images/ path.
IMG_PUBLIC_BASE=https://173.212.247.3.nip.io/images

# ── SMTP (password reset emails) ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=                      # Gmail app-password, not account password
SMTP_FROM=GRP Support AI <noreply@example.com>
SMTP_USE_TLS=true
