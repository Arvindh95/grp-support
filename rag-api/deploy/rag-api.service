[Unit]
Description=GRP RAG-API (multi-agent RFS analysis)
After=network.target redis-server.service elasticsearch.service ollama.service
Wants=redis-server.service elasticsearch.service ollama.service

[Service]
Type=simple
User=claudeuser
Group=claudeuser
WorkingDirectory=/opt/grp-chat/rag-api
Environment=PYTHONPATH=/home/claudeuser/.local/lib/python3.12/site-packages
EnvironmentFile=/etc/rag-api.env
ExecStart=/home/claudeuser/.local/bin/uvicorn app.main:app \
    --host 127.0.0.1 \
    --port 8001 \
    --workers 1 \
    --log-level info
Restart=on-failure
RestartSec=3
KillSignal=SIGINT
TimeoutStopSec=20

# Hardening — ProtectHome omitted: uvicorn + deps live under /home/claudeuser/.local
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full

[Install]
WantedBy=multi-user.target
