# /etc/rag-api.env  (chmod 640, owner root:claudeuser)
# Source of truth for the rag-api systemd service.

# Elasticsearch (shared with grp-api)
ES_URL=https://127.0.0.1:9200
ES_USER=elastic
ES_PASSWORD=CHANGE_ME
ES_VERIFY_TLS=0

# Redis  — use DB 3 to stay clear of CSAI-OCR (DB 0) on the same host
REDIS_URL=redis://127.0.0.1:6379/3

# Anthropic
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# Webhook signing (single shared secret for v1; per-key registry lands W11+)
WEBHOOK_DEFAULT_SECRET=CHANGE_ME_to_a_64hex_random
# Optional comma-separated host allowlist for callback_url. Leave empty to
# allow any PUBLIC host (private/loopback/link-local IPs are always blocked).
WEBHOOK_ALLOWED_HOSTS=

# Limits
RATE_LIMIT_PER_MINUTE=60
# Body cap. Inline base64 attachments are large — 25 MB of files ~= 34 MB
# of base64. Keep this >= nginx client_max_body_size (40m).
MAX_BODY_BYTES=41943040
# Total decoded size of all attachments on one RFS (25 MB). Anthropic's hard
# request ceiling is 32 MB / 100 PDF pages — keep real usage well under.
MAX_ATTACHMENT_BYTES=26214400
IDEMPOTENCY_TTL=86400
JOB_TTL=604800

# Worker
WORKER_CONCURRENCY=2
WORKER_POLL_INTERVAL=0.5

# Budget — set to a positive integer to enforce a monthly token cap
MONTHLY_TOKEN_BUDGET=0

# LLM transient-failure retry. On a 429 / 5xx / 529-overloaded / connection
# error, call_messages retries with exponential backoff + jitter before
# giving up. Backoff per attempt: base, base*2, base*4, ... capped at 30s.
LLM_MAX_RETRIES=5
LLM_RETRY_BASE_SECONDS=4.0

# Observability
LOG_LEVEL=INFO
TRACE_INDEX_PREFIX=rag-api-trace
